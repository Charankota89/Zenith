<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- Home / Dashboard -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.zenith.app.ui.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <!-- Module 1 – Screen Control -->
    <fragment
        android:id="@+id/usageFragment"
        android:name="com.zenith.app.module1_screen.usage.UsageFragment"
        android:label="Screen Time"
        tools:layout="@layout/fragment_usage" />

    <!-- Module 2 – Focus (placeholder fragments added as features are built) -->
    <fragment
        android:id="@+id/focusFragment"
        android:name="com.zenith.app.ui.PlaceholderFragment"
        android:label="Focus" />

    <!-- Module 3 – Career -->
    <fragment
        android:id="@+id/careerFragment"
        android:name="com.zenith.app.ui.PlaceholderFragment"
        android:label="Career" />

    <!-- Module 4 – Wellbeing -->
    <fragment
        android:id="@+id/wellbeingFragment"
        android:name="com.zenith.app.ui.PlaceholderFragment"
        android:label="Wellbeing" />

</navigation>
