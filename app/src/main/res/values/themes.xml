<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Zenith" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/zenith_purple</item>
        <item name="colorPrimaryVariant">@color/zenith_dark</item>
        <item name="colorAccent">@color/zenith_teal</item>
        <item name="android:colorBackground">@color/zenith_lavender</item>
        <item name="android:windowBackground">@color/zenith_lavender</item>
    </style>

    <style name="Theme.Zenith.Splash" parent="Theme.Zenith">
        <item name="android:colorBackground">@color/zenith_dark</item>
        <item name="android:windowBackground">@color/zenith_dark</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
