<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zenith_lavender">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:clipChildren="false">

            <!-- Soft decorative gradient blob, purely visual, sits behind the text -->
            <View
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="-40dp"
                android:layout_marginEnd="-30dp"
                android:background="@drawable/grad_header_blob"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/btnSettings">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvTagline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_settings_button"
                android:src="@android:drawable/ic_menu_preferences"
                android:contentDescription="Settings"
                android:tint="@color/white"
                android:padding="12dp"
                android:elevation="4dp"/>
        </RelativeLayout>

        <!-- Permission warning card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPermissionWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#2D1F24"
            android:visibility="gone"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:id="@+id/tvPermissionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ System Permissions Required"
                    android:textColor="#FCA5A5"
                    android:textStyle="bold"
                    android:textSize="15sp"/>
                <TextView
                    android:id="@+id/tvPermissionDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zenith needs Accessibility Service to track active apps and Overlay permission to display lock screens. Tap below to configure."
                    android:textColor="#FECACA"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGrantPermissions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enable Zenith Protector"
                    android:textSize="12sp"
                    android:background="@drawable/grad_button_coral"
                    app:backgroundTint="@null"
                    app:cornerRadius="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Screen Time Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardScreenTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#E6242540"
            app:strokeWidth="1dp"
            app:strokeColor="#147C3AED"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/surface_card">
                <View
                    android:layout_width="5dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/grad_accent_purple"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱 SCREEN TIME TODAY"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:id="@+id/tvScreenTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0h 0m"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Habits Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHabits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#E6242540"
            app:strokeWidth="1dp"
            app:strokeColor="#147C3AED"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/surface_card">
                <View
                    android:layout_width="5dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/grad_accent_teal"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅ HABIT PROGRESS"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:id="@+id/tvHabitCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 habits done"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/zenith_teal"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Study Time Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStudyTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#E6242540"
            app:strokeWidth="1dp"
            app:strokeColor="#147C3AED"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/surface_card">
                <View
                    android:layout_width="5dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/grad_accent_amber"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📚 STUDY TIME"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:id="@+id/tvStudyTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0m studied"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/zenith_amber"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
