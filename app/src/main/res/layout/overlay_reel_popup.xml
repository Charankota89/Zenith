<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/reel_popup_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="210dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_floating_capsule"
    android:paddingStart="14dp"
    android:paddingEnd="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:clickable="true"
    android:focusable="false">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎬"
        android:textSize="15sp"
        android:layout_marginEnd="10dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvReelCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 reels watched"
            android:textSize="12sp"
            android:fontFamily="@font/outfit_700"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/tvReelTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 min on reels — still worth it?"
            android:textSize="10sp"
            android:fontFamily="@font/outfit_400"
            android:textColor="#CBD5E1"
            android:layout_marginTop="1dp"/>
    </LinearLayout>
</LinearLayout>
