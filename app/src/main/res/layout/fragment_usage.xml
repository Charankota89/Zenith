<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── Permission Banner ── -->
            <LinearLayout
                android:id="@+id/bannerNoPermission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_warning_banner"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Usage Access Required"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Zenith needs Usage Access permission to track your screen time. Tap below to grant it."
                    android:textColor="#B0BEC5"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnGrantUsage"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/zenith_purple"
                    android:text="Grant Permission"
                    android:textColor="@color/white"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- ── Content (visible when permission granted) ── -->
            <LinearLayout
                android:id="@+id/contentGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Today Total Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TODAY'S SCREEN TIME"
                            android:textColor="#7C83A0"
                            android:textSize="11sp"
                            android:letterSpacing="0.12" />

                        <TextView
                            android:id="@+id/tvTodayTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="0m"
                            android:textColor="@color/white"
                            android:textSize="48sp"
                            android:textStyle="bold"
                            tools:text="3h 24m" />

                        <TextView
                            android:id="@+id/tvAppCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0 apps tracked"
                            android:textColor="#7C83A0"
                            android:textSize="13sp"
                            tools:text="12 apps tracked" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Weekly Bar Chart Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="WEEKLY OVERVIEW"
                            android:textColor="#7C83A0"
                            android:textSize="11sp"
                            android:letterSpacing="0.12" />

                        <com.github.mikephil.charting.charts.BarChart
                            android:id="@+id/chartWeeklyUsage"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Today's Apps Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="TODAY'S APPS"
                    android:textColor="#7C83A0"
                    android:textSize="11sp"
                    android:letterSpacing="0.12" />

                <!-- No data state -->
                <TextView
                    android:id="@+id/tvNoData"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="32dp"
                    android:text="Pull down to refresh usage data"
                    android:textColor="#4A4F6A"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <!-- App usage list (non-scrolling inside ScrollView) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerUsage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="5"
                    tools:listitem="@layout/item_app_usage" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
