<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#CC0A0A14">

    <TextView
        android:id="@+id/tvLockedApp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="App is locked"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvLockedReason"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="You set this limit — keep going."
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnGoBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Go Back"
        android:backgroundTint="@color/zenith_purple"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnUnlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Unlock Anyway"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:textColor="@color/white"/>
</LinearLayout>
