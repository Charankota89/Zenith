<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#F20A0A14">

    <!-- Lock icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔒"
        android:textSize="56sp"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/tvLockedApp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="App is locked"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/tvLockedReason"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="You set this limit — keep going."
        android:textSize="15sp"
        android:textColor="#B0B4CC"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnGoHome"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="🏠  Go to Home Screen"
        android:backgroundTint="#7C6FE0"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnGoBack"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="← Go Back"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:textColor="#B0B4CC"/>
</LinearLayout>
