<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F20A0A14">

    <LinearLayout
        android:id="@+id/layoutLockContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Lock icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒"
            android:textSize="56sp"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvLockedApp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="App is locked"
            android:textSize="24sp"
            android:fontFamily="@font/outfit_800"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tvLockedReason"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You set this limit — keep going."
            android:textSize="15sp"
            android:fontFamily="@font/outfit_400"
            android:textColor="#94A3B8"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="48dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoHome"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🏠  Go to Home Screen"
            android:background="@drawable/grad_button_purple"
            app:backgroundTint="@null"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/outfit_700"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"/>

        <!-- Unlock details input before requesting email link -->
        <LinearLayout
            android:id="@+id/layoutRequestEmailDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Why do you need to unlock?"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/outfit_700"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etUnlockReason"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="e.g., Quick check on messages"
                android:textColor="#FFFFFF"
                android:textColorHint="#94A3B8"
                android:background="@drawable/bg_lock_input"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:fontFamily="@font/outfit_400"
                android:textSize="14sp"
                android:layout_marginBottom="14dp"
                android:inputType="text"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select unlock duration"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/outfit_700"
                android:layout_marginBottom="8dp"/>

            <!-- Select duration radio items -->
            <RadioGroup
                android:id="@+id/rgDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">
                <RadioButton
                    android:id="@+id/rb5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 min"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/outfit_500"
                    android:buttonTint="@color/zenith_teal"
                    android:checked="true"/>
                <RadioButton
                    android:id="@+id/rb15"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15 min"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/outfit_500"
                    android:buttonTint="@color/zenith_teal"
                    android:layout_marginStart="8dp"/>
                <RadioButton
                    android:id="@+id/rb30"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30 min"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/outfit_500"
                    android:buttonTint="@color/zenith_teal"
                    android:layout_marginStart="8dp"/>
            </RadioGroup>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendEmail"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="📧 Send Verification Email"
                android:background="@drawable/grad_button_teal"
                app:backgroundTint="@null"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/outfit_700"
                android:textSize="15sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutEmailSent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✉️"
                android:textSize="32sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvEmailSentMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Verification link sent to your registered email! Please click the link inside the email (or click the notification banner) to unlock the app."
                android:textColor="#FFFFFF"
                android:fontFamily="@font/outfit_400"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <ProgressBar
                android:id="@+id/pbEmailWaiting"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:indeterminateTint="@color/zenith_teal"
                android:layout_marginBottom="8dp"
                style="?android:attr/progressBarStyleSmall"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Waiting for email verification link click..."
                android:textColor="#94A3B8"
                android:fontFamily="@font/outfit_400"
                android:textSize="12sp"
                android:textStyle="italic"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoBack"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="← Go Back"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="#94A3B8"
            android:fontFamily="@font/outfit_600"
            app:strokeColor="#94A3B8"/>
    </LinearLayout>
</ScrollView>
