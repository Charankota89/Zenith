<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/capsule_container"
    android:layout_width="160dp"
    android:layout_height="36dp"
    android:background="@drawable/bg_floating_capsule"
    android:orientation="vertical"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Real app icon (set programmatically) -->
        <ImageView
            android:id="@+id/ivCapsuleAppIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="6dp"
            android:contentDescription="App icon"/>

        <!-- Status Dot Indicator -->
        <View
            android:id="@+id/viewStatusDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/circle_status"
            android:layout_marginEnd="8dp"/>

        <!-- Text Display -->
        <TextView
            android:id="@+id/tvCapsuleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="15m left"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"/>

        <!-- Clock emoji icon -->
        <TextView
            android:id="@+id/tvCapsuleIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏱️"
            android:textSize="12sp"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- Thin usage progress bar, sits right below the row -->
    <ProgressBar
        android:id="@+id/progressCapsuleUsage"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginTop="4dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/bg_capsule_progress"/>

    <!-- Expanded content -->
    <LinearLayout
        android:id="@+id/layoutExpandedDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="6dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#334155"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvExpandedDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#CBD5E1"
            android:textSize="9sp"
            android:text="Daily Limit: 30m\nTime Used: 15m"/>
    </LinearLayout>

</LinearLayout>
