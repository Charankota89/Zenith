<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/screen_on_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="260dp"
    android:orientation="vertical"
    android:background="@drawable/bg_floating_capsule"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:clickable="true"
    android:focusable="false">

    <!-- Header row: brand + clock + close -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ZENITH"
            android:textSize="10sp"
            android:fontFamily="@font/outfit_800"
            android:letterSpacing="0.15"
            android:textColor="#A78BFA"/>

        <TextView
            android:id="@+id/tvScreenOnTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="9:41 AM"
            android:textSize="10sp"
            android:fontFamily="@font/outfit_500"
            android:textColor="#94A3B8"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/btnScreenOnClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:padding="2dp"/>
    </LinearLayout>

    <!-- Goal row: real target vs actual usage, single compact line -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎯"
            android:textSize="13sp"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/tvScreenOnGoalLine"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0m of 2h 0m goal"
            android:textSize="12sp"
            android:fontFamily="@font/outfit_700"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/tvScreenOnGoalPct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="11sp"
            android:fontFamily="@font/outfit_700"
            android:textColor="#94A3B8"/>
    </LinearLayout>

    <!-- Progress bar toward the goal — same visual language as the
         Dynamic Island's usage bar -->
    <ProgressBar
        android:id="@+id/progressScreenOnGoal"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginBottom="8dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/bg_capsule_progress"/>

    <!-- Compact secondary stats: habits + focus sessions on one line -->
    <TextView
        android:id="@+id/tvScreenOnSecondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✅ 0/0 habits   ·   🧠 0 sessions"
        android:textSize="10sp"
        android:fontFamily="@font/outfit_500"
        android:textColor="#94A3B8"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/tvScreenOnMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Stay focused. Every minute counts. ⚡"
        android:textSize="10sp"
        android:fontFamily="@font/outfit_400"
        android:textColor="#CBD5E1"/>

</LinearLayout>
