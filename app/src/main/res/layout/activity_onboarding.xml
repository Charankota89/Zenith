<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/zenith_dark">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/tvDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="48dp"/>

    <!-- Dot indicators -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="40dp">
        <View android:id="@+id/dot1"
            android:layout_width="10dp" android:layout_height="10dp"
            android:background="@color/zenith_purple" android:layout_marginEnd="6dp"/>
        <View android:id="@+id/dot2"
            android:layout_width="10dp" android:layout_height="10dp"
            android:background="@color/zenith_purple" android:layout_marginEnd="6dp"/>
        <View android:id="@+id/dot3"
            android:layout_width="10dp" android:layout_height="10dp"
            android:background="@color/zenith_purple"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_next"
        android:backgroundTint="@color/zenith_purple"
        android:textColor="@color/white"
        android:textSize="16sp"/>

    <Button
        android:id="@+id/btnGoogleSignIn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Sign in with Google"
        android:backgroundTint="@color/white"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        android:elevation="2dp"/>
</LinearLayout>
